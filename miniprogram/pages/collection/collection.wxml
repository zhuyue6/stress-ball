<view class="page">
  <view class="hero">
    <text class="hero-title">我的捏捏收藏</text>
    <text class="hero-sub">无进度压力，点亮只是小惊喜 ✨</text>
  </view>

  <view class="section">
    <text class="section-title">造型</text>
    <view class="grid">
      <view
        wx:for="{{toys}}"
        wx:key="id"
        class="card {{item.unlocked ? '' : 'locked'}}"
      >
        <text class="card-emoji">{{item.emoji}}</text>
        <text class="card-name">{{item.name}}</text>
        <text wx:if="{{item.unlocked}}" class="badge ok">已解锁</text>
        <text wx:else class="badge">未解锁</text>
      </view>
    </view>
  </view>

  <view class="section">
    <text class="section-title">场景</text>
    <view class="grid scene-grid">
      <view
        wx:for="{{scenes}}"
        wx:key="id"
        class="card scene {{item.unlocked ? '' : 'locked'}}"
      >
        <view class="scene-bg" style="background: {{item.gradient}}"></view>
        <text class="card-name">{{item.name}}</text>
        <text wx:if="{{item.unlocked}}" class="badge ok">已解锁</text>
        <text wx:else class="badge">未解锁</text>
      </view>
    </view>
  </view>

  <view class="stats card-stats">
    <text>累计放松约 {{playMinutes}} 分钟</text>
  </view>

  <custom-tab-bar current="collection" />
</view>
