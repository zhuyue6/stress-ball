.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff5f7 0%, #fafafa 40%);
  padding: 32rpx 28rpx 200rpx;
  box-sizing: border-box;
}

.hero {
  margin-bottom: 36rpx;
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #444444;
  margin-bottom: 12rpx;
}

.hero-sub {
  font-size: 24rpx;
  color: #888888;
  line-height: 1.5;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #666666;
  margin-bottom: 20rpx;
  display: block;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.card {
  width: 100%;
  min-width: 0;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.card.locked {
  opacity: 0.55;
}

.card-emoji {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.card-name {
  font-size: 24rpx;
  color: #555555;
  text-align: center;
  margin-bottom: 8rpx;
}

.badge {
  font-size: 20rpx;
  color: #aaaaaa;
}

.badge.ok {
  color: #5a9e6a;
  font-weight: 600;
}

.scene-grid .card.scene {
  min-height: 200rpx;
}

.scene-bg {
  width: 100%;
  height: 100rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.card-stats {
  padding: 24rpx;
  background: rgba(255, 182, 193, 0.2);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #666666;
  text-align: center;
}
