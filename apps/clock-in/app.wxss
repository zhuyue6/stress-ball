/**
 * 全局治愈系基础样式 — 马卡龙低饱和、柔和圆角（与 constraint 一致）
 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica,
    'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #444444;
  background-color: #fafafa;
  box-sizing: border-box;
}

.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.btn-primary {
  background: linear-gradient(135deg, #7dd3b0 0%, #5cb894 100%);
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 30rpx;
  padding: 22rpx 40rpx;
  border: none;
}

.btn-ghost {
  background: #f3f3f3;
  color: #555555;
  border-radius: 16rpx;
  font-size: 28rpx;
  padding: 18rpx 32rpx;
  border: none;
}

.text-muted {
  color: #888888;
  font-size: 24rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #e8f7f0;
  color: #3d8b6e;
}
