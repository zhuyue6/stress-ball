<view class="page safe-bottom">
  <view class="card field-card">
    <text class="label">关联主目标</text>
    <picker mode="selector" range="{{goals}}" range-key="name" value="{{goalIndex}}" bindchange="onGoalChange">
      <view class="picker-val">{{goals[goalIndex].name}}</view>
    </picker>
  </view>
  <view class="card field-card">
    <text class="label">子目标（可选）</text>
    <picker mode="selector" range="{{subOptions}}" range-key="name" value="{{subIndex}}" bindchange="onSubChange">
      <view class="picker-val">{{subOptions[subIndex].name}}</view>
    </picker>
  </view>
  <view class="card field-card">
    <text class="label">提醒类型</text>
    <picker mode="selector" range="{{typeLabels}}" value="{{typeIndex}}" bindchange="onTypeChange">
      <view class="picker-val">{{typeLabels[typeIndex]}}</view>
    </picker>
  </view>
  <view wx:if="{{typeIndex === 0}}" class="card field-card">
    <text class="label">每日提醒时间</text>
    <picker mode="time" value="{{time}}" bindchange="onTimeChange">
      <view class="picker-val">{{time}}</view>
    </picker>
  </view>
  <view wx:if="{{typeIndex === 1}}" class="card field-card">
    <text class="label">截止前（天）</text>
    <input class="input" type="number" value="{{beforeDays}}" bindinput="onBeforeDaysInput" />
  </view>
  <view class="card field-card">
    <text class="label">触达渠道</text>
    <view class="switch-row">
      <text>打开小程序时的站内提示</text>
      <switch checked="{{channelInApp}}" bindchange="onInAppChange" />
    </view>
    <view class="switch-row">
      <text>订阅消息（须配置模板 + 服务端发送）</text>
      <switch checked="{{channelSubscribe}}" bindchange="onSubscribeChange" />
    </view>
    <text class="text-muted small">{{quietHint}}</text>
  </view>
  <button class="btn-primary save-btn" bindtap="onSave">保存</button>
  <button wx:if="{{id}}" class="btn-ghost del-btn" bindtap="onDelete">删除</button>
</view>
