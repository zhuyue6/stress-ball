<view class="page safe-bottom">
  <view class="header">
    <text class="hint text-muted">提醒不强制订阅；关闭「站内」后仅保留列表记录。</text>
    <button class="btn-add" bindtap="onAddTap">+ 新建提醒</button>
  </view>

  <view wx:if="{{rows.length === 0}}" class="card empty">暂无提醒，可为重要目标设置固定时间或截止预警。</view>

  <block wx:for="{{rows}}" wx:key="id">
    <view class="card row" data-id="{{item.id}}" bindtap="onRowTap">
      <view class="row-top">
        <text class="goal-name">{{item.goalName}}</text>
        <switch checked="{{item.enabled}}" data-id="{{item.id}}" catchchange="onSwitchChange" />
      </view>
      <text wx:if="{{item.subName}}" class="text-muted sub">子目标：{{item.subName}}</text>
      <text class="type-line">{{item.typeLabel}}</text>
      <view class="chips">
        <text class="chip" wx:if="{{item.channels.inApp}}">站内</text>
        <text class="chip" wx:if="{{item.channels.subscribe}}">订阅消息</text>
      </view>
    </view>
  </block>
</view>
