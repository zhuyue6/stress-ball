.page {
  padding: 24rpx 28rpx 120rpx;
  min-height: 100vh;
}

.header {
  margin-bottom: 20rpx;
}

.hint {
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.btn-add {
  background: #e8f7f0;
  color: #3d8b6e;
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  border: none;
  margin: 0;
}

.empty {
  text-align: center;
  color: #888888;
  padding: 48rpx 24rpx;
}

.row-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.goal-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  flex: 1;
}

.sub {
  display: block;
  margin-bottom: 8rpx;
}

.type-line {
  font-size: 26rpx;
  color: #555555;
  margin-bottom: 12rpx;
}

.chips {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.chip {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #e3f4ff;
  color: #3a7ca5;
}
