.page {
  padding: 24rpx 28rpx 120rpx;
}

.field-card {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.input {
  font-size: 30rpx;
  padding: 16rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  padding: 16rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.picker-val {
  padding: 16rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333333;
}

.save-btn {
  width: 100%;
  margin-top: 32rpx;
}
