.page {
  padding: 24rpx 28rpx 120rpx;
  min-height: 100vh;
}

.main-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  flex: 1;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.block {
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.row-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.tag-soft {
  background: #fff5e6;
  color: #b8860b;
}

.status-active {
  background: #e3f4ff;
  color: #3a7ca5;
}

.status-done {
  background: #e8f7f0;
  color: #3d8b6e;
}

.status-expired {
  background: #f0f0f0;
  color: #888888;
}

.progress-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #eeeeee;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  background: linear-gradient(90deg, #a8e6cf 0%, #5cb894 100%);
  border-radius: 999rpx;
}

.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.btn-ghost.sm {
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  margin: 0;
}

.btn-ghost.danger {
  background: #fff0f0;
  color: #c45c5c;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 8rpx 0 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.btn-mini {
  background: #e8f7f0;
  color: #3d8b6e;
  font-size: 24rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  border: none;
  margin: 0;
}

.empty {
  color: #888888;
  text-align: center;
  padding: 32rpx;
}

.sub-card {
  margin-bottom: 20rpx;
}

.sub-info {
  flex: 1;
  min-width: 0;
}

.sub-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  display: block;
}

.sub-meta {
  display: block;
  margin-top: 8rpx;
}

.sub-status-active {
  background: #e3f4ff;
  color: #3a7ca5;
}

.sub-status-done {
  background: #e8f7f0;
  color: #3d8b6e;
}

.sub-status-expired {
  background: #f0f0f0;
  color: #888888;
}

.checkin-btn {
  width: 100%;
  margin-top: 20rpx;
  font-size: 28rpx;
}

.mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 500;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.sheet {
  width: 100%;
  max-height: 85vh;
  overflow-y: auto;
  border-radius: 24rpx 24rpx 0 0;
  margin: 0;
}

.sheet-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.note-area {
  width: 100%;
  min-height: 160rpx;
  padding: 16rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.img-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
}

.img-wrap {
  position: relative;
}

.img-remove {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
}

.img-add {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  border: 2rpx dashed #cccccc;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #888888;
  font-size: 26rpx;
}

.hint {
  display: block;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.sheet-actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.sheet-actions .btn-ghost,
.sheet-actions .btn-primary {
  flex: 1;
  margin: 0;
}

.recent-title {
  display: block;
  margin-bottom: 12rpx;
}

.recent-line {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 24rpx;
}
