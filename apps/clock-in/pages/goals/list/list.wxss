.page {
  padding: 24rpx 28rpx 120rpx;
  min-height: 100vh;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.btn-add {
  background: #e8f7f0;
  color: #3d8b6e;
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  border: none;
  margin: 0;
}

.empty {
  text-align: center;
  color: #888888;
  padding: 48rpx 24rpx;
}

.goal-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.goal-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  flex: 1;
}

.status-active {
  background: #e3f4ff;
  color: #3a7ca5;
}

.status-done {
  background: #e8f7f0;
  color: #3d8b6e;
}

.status-expired {
  background: #f0f0f0;
  color: #888888;
}

.goal-desc {
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.goal-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.tag-soft {
  background: #fff5e6;
  color: #b8860b;
}

.progress-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #eeeeee;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  background: linear-gradient(90deg, #a8e6cf 0%, #5cb894 100%);
  border-radius: 999rpx;
}

.progress-text {
  min-width: 72rpx;
  text-align: right;
}

.mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.dialog {
  width: 100%;
  max-width: 600rpx;
}

.dialog-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: #333333;
}

.dialog-body {
  display: block;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.dialog-btn {
  width: 100%;
}
