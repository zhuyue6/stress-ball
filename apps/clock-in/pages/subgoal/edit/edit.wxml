<view class="page safe-bottom">
  <view class="card field-card">
    <text class="label">名称</text>
    <input class="input" placeholder="例如：看完《民法》" value="{{name}}" bindinput="onNameInput" maxlength="40" />
  </view>
  <view class="card field-card">
    <text class="label">打卡频率</text>
    <picker mode="selector" range="{{freqLabels}}" value="{{freqIndex}}" bindchange="onFreqChange">
      <view class="picker-val">{{freqLabels[freqIndex]}}</view>
    </picker>
  </view>
  <view class="card field-card">
    <text class="label">子目标截止日</text>
    <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
      <view class="picker-val">{{endDate || '不设置'}}</view>
    </picker>
  </view>
  <view wx:if="{{id}}" class="card field-card">
    <text class="label">状态</text>
    <picker mode="selector" range="{{['进行中','已完成','已过期']}}" value="{{status === 'active' ? 0 : status === 'done' ? 1 : 2}}" bindchange="onStatusChange">
      <view class="picker-val">{{status === 'done' ? '已完成' : status === 'expired' ? '已过期' : '进行中'}}</view>
    </picker>
  </view>
  <button class="btn-primary save-btn" bindtap="onSave">保存</button>
  <button wx:if="{{id}}" class="btn-ghost del-btn" bindtap="onDelete">删除子目标</button>
</view>
