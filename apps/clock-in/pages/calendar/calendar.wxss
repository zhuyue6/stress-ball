.page {
  padding: 24rpx 28rpx 120rpx;
  min-height: 100vh;
}

.nav-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.nav-btn {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  margin: 0;
  background: #e8f7f0;
  color: #3d8b6e;
  border-radius: 16rpx;
  font-size: 36rpx;
  border: none;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.legend {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #5cb894;
  margin: 8rpx auto 0;
}

.dot.on {
  margin: 0;
}

.week-head {
  display: flex;
  margin-bottom: 8rpx;
}

.wd {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #888888;
}

.grid {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.row {
  display: flex;
}

.cell {
  flex: 1;
  min-height: 96rpx;
  text-align: center;
  padding: 8rpx 0;
  border-radius: 12rpx;
}

.cell.empty {
  visibility: hidden;
}

.cell.today {
  background: #e8f7f0;
}

.day-num {
  font-size: 26rpx;
  color: #333333;
}

.foot {
  display: block;
  margin-top: 24rpx;
  line-height: 1.5;
  padding: 0 8rpx;
}
