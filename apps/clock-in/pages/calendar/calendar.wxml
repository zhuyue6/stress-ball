<view class="page safe-bottom">
  <view class="card nav-card">
    <button class="nav-btn" bindtap="prevMonth">‹</button>
    <text class="nav-title">{{title}}</text>
    <button class="nav-btn" bindtap="nextMonth">›</button>
  </view>
  <view class="legend card">
    <view class="dot on" />
    <text class="text-muted">当日有打卡</text>
  </view>
  <view class="week-head">
    <text wx:for="{{['日','一','二','三','四','五','六']}}" wx:key="*this" class="wd">{{item}}</text>
  </view>
  <view class="grid">
    <block wx:for="{{weeks}}" wx:for-item="row" wx:key="*this">
      <view class="row">
        <block wx:for="{{row}}" wx:for-item="cell" wx:for-index="ci" wx:key="ci">
          <view wx:if="{{cell.empty}}" class="cell empty" />
          <view wx:else class="cell {{cell.isToday ? 'today' : ''}}">
            <text class="day-num">{{cell.day}}</text>
            <view wx:if="{{cell.checked}}" class="dot" />
          </view>
        </block>
      </view>
    </block>
  </view>
  <text class="text-muted foot">仅汇总本机打卡记录；接入云开发后可跨设备同步。</text>
</view>
