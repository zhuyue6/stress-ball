.page {
  padding: 24rpx 28rpx 120rpx;
  min-height: 100vh;
}

.stats-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  color: #333333;
}

.stats-row {
  display: flex;
  justify-content: space-between;
  text-align: center;
}

.cell {
  flex: 1;
}

.num {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #5cb894;
  margin-bottom: 8rpx;
}

.block-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #333333;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 28rpx;
  color: #333333;
}

.small {
  display: block;
  margin-top: 12rpx;
  line-height: 1.6;
}

.row-btn {
  width: 100%;
  margin-top: 16rpx;
  background: #fff0f0;
  color: #c45c5c;
  border-radius: 16rpx;
  font-size: 28rpx;
  border: none;
}

.row-btn.ghost {
  background: #f3f3f3;
  color: #555555;
}

.foot {
  display: block;
  margin-top: 32rpx;
  line-height: 1.6;
  padding: 0 8rpx;
}
