<view class="page safe-bottom">
  <view class="card stats">
    <text class="stats-title">数据概览</text>
    <view class="stats-row">
      <view class="cell">
        <text class="num">{{activeCount}}</text>
        <text class="text-muted">进行中目标</text>
      </view>
      <view class="cell">
        <text class="num">{{doneCount}}</text>
        <text class="text-muted">已完成目标</text>
      </view>
      <view class="cell">
        <text class="num">{{checkinCount}}</text>
        <text class="text-muted">累计打卡次数</text>
      </view>
    </view>
  </view>

  <view class="card">
    <text class="block-title">提醒与可选增强</text>
    <view class="switch-row">
      <text>打开小程序时的站内提示</text>
      <switch checked="{{inAppReminder}}" bindchange="onInAppSwitch" />
    </view>
    <view class="switch-row">
      <text>愿意接收公众号提醒（偏好记录）</text>
      <switch checked="{{mpOptIn}}" bindchange="onMpOptInChange" />
    </view>
    <text class="text-muted small">{{mpNote}}</text>
  </view>

  <view class="card">
    <text class="block-title">数据与反馈</text>
    <button class="row-btn" bindtap="onClearData">清空本地数据</button>
    <button class="row-btn ghost" bindtap="onFeedback">意见反馈说明</button>
  </view>

  <text class="text-muted foot">本版本数据存于本机；上线请配置隐私指引、订阅模板与（如需）云开发环境。</text>
</view>
