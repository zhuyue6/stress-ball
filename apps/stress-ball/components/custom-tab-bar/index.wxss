.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 12rpx 24rpx 20rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.06);
  border-radius: 24rpx 24rpx 0 0;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
  border-radius: 16rpx;
  transition: background 0.2s ease;
}

.tab-item.active {
  background: rgba(255, 182, 193, 0.25);
}

.tab-icon {
  font-size: 40rpx;
  line-height: 1.2;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #888888;
}

.tab-item.active .tab-text {
  color: #C77B9E;
  font-weight: 600;
}
